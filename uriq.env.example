# Copy to uriq.env (local) or set in Hostinger hPanel → Node.js → Environment
#
# REQUIRED for login, profiles, dashboard sync:
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your_publishable_or_anon_key
#
# OPTIONAL — server-only admin tasks (NOT needed for normal app use):
# SUPABASE_SECRET_KEY=your_service_role_secret
#
# OPTIONAL — custom logo from GitHub raw URL (defaults to public/logo.svg):
# NEXT_PUBLIC_LOGO_URL=https://raw.githubusercontent.com/phildass/uriq-in/main/public/logo.svg
#
# Translation: free Google Translate widget in navbar — no API key required.
