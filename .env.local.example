# Supabase credentials live in uriq.env (loaded automatically via next.config.ts)
#
# uriq.env example:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_KEY=your_publishable_or_anon_key
# SUPABASE_SECRET_KEY=your_service_role_secret   # server-only, never expose to client
#
# The app maps NEXT_PUBLIC_SUPABASE_KEY -> NEXT_PUBLIC_SUPABASE_ANON_KEY
