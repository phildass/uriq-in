# Supabase credentials live in uriq.env (loaded automatically via next.config.js)
#
# REQUIRED:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_KEY=your_publishable_or_anon_key
#
# The app maps NEXT_PUBLIC_SUPABASE_KEY -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# NOT REQUIRED for normal use:
# SUPABASE_SECRET_KEY (service role — admin/server only)
#
# Translation uses free Google Translate widget — no GOOGLE_TRANSLATE_API_KEY needed.
